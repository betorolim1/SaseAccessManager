@page
@model SaseAccessManager.Pages.Users.IndexModel

<style>
    .status-active {
        background-color: #e6ffed;
    }
    /* verde claro */
    .status-error {
        background-color: #ffe6e6;
    }
    /* vermelho claro */
    .status-removed {
        background-color: #f0f0f0;
    }
    /* cinza */

    .status-text-active {
        color: #0a7a2f;
        font-weight: bold;
    }

    .status-text-error {
        color: #b00020;
        font-weight: bold;
    }

    .status-text-removed {
        color: #666;
        font-weight: bold;
    }

    .mb-16 {
        margin-bottom: 16px;
    }

    .btn {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        border: 1px solid transparent;
        cursor: pointer;
        font-size: 14px;
    }

    .btn-primary {
        background-color: #2563eb;
        color: white;
    }

        .btn-primary:hover {
            background-color: #1d4ed8;
        }

    .btn-danger {
        background-color: #dc2626;
        color: white;
    }

        .btn-danger:hover {
            background-color: #b91c1c;
        }

    .table {
        border-collapse: collapse;
        width: 100%;
        font-size: 14px;
    }

        .table th {
            background: #f3f4f6;
            text-align: left;
            padding: 14px 12px;
            border-bottom: 2px solid #e5e7eb;
        }

        .table td {
            padding: 14px 12px;
            border-bottom: 1px solid #e5e7eb;
            vertical-align: middle;
            height: 75px;
        }

        .table tbody tr:hover {
            background: #f9fafb;
        }

    .table-container {
        margin-top: 10px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .expire-today {
        color: #d97706;
        font-weight: 600;
    }

    .expire-ok {
        color: #15803d;
        font-weight: 600;
    }

    .expire-expired {
        color: #b91c1c;
        font-weight: 600;
    }

    .table th:last-child,
    .table td:last-child {
        width: 120px;
        text-align: center;
    }

    .badge {
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
    }

    .badge-active {
        background: #dcfce7;
        color: #166534;
    }

    .badge-error {
        background: #fee2e2;
        color: #991b1b;
    }

    .badge-removed {
        background: #e5e7eb;
        color: #374151;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .header-actions {
        display: flex;
        gap: 8px;
    }

    .page-actions {
        margin-bottom: 14px;
    }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        padding: 10px 12px;
        border-radius: 6px;
        margin-bottom: 15px;
        font-weight: 600;
    }

    .toast {
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 14px 18px;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        box-shadow: 0 6px 16px rgba(0,0,0,0.2);
        z-index: 9999;
        animation: fadeIn 0.3s ease;
    }

        .toast.success {
            background: #16a34a;
        }

        .toast.error {
            background: #dc2626;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@if (TempData["ToastMessage"] != null)
{
    <div id="toast"
         class="toast @(TempData["ToastType"])">

        @TempData["ToastMessage"]
    </div>
}

<div class="page-header">
    <h2>Usuários Temporários</h2>

    <div class="header-actions">
        <a href="/Users/Create" class="btn btn-primary">
            + Criar novo usuário
        </a>
    </div>

    <div class="page-actions">
        <button class="btn btn-secondary" onclick="this.innerText='Atualizando...'; location.reload();">
            ⟳ Atualizar página
        </button>
    </div>
</div>

@functions {
    string RowClass(UserStatus status) => status switch
    {
        UserStatus.Active => "status-active",
        UserStatus.Error => "status-error",
        UserStatus.Removed => "status-removed",
        _ => ""
    };

    string TextClass(UserStatus status) => status switch
    {
        UserStatus.Active => "status-text-active",
        UserStatus.Error => "status-text-error",
        UserStatus.Removed => "status-text-removed",
        _ => ""
    };

    string StatusBadge(UserStatus status) => status switch
    {
        UserStatus.Active => "badge badge-active",
        UserStatus.Error => "badge badge-error",
        UserStatus.Removed => "badge badge-removed",
        _ => "badge"
    };
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert-error">
        @Model.ErrorMessage
    </div>
}

<div class="table-container">
    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Nome</th>
                <th>Criado em </th>
                <th>Expira em </th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Users)
            {
                <tr class="@RowClass(u.Status)">
                    <td>@u.Email</td>
                    <td>@u.Name @u.LastName</td>
                    <td>@u.CreatedAt.ToLocalTime()</td>
                    <td>
                        @if (u.Status == UserStatus.Removed)
                        {
                            <span>-</span>
                        }
                        else
                        {
                            var remaining = u.ExpiresAt - DateTime.UtcNow;

                            if (remaining.TotalSeconds <= 0)
                            {
                                <span class="expire-expired">Expirado</span>
                            }
                            else if (remaining.TotalDays < 1)
                            {
                                <span class="expire-today">Hoje</span>
                            }
                            else
                            {
                                <span class="expire-ok">@Math.Floor(remaining.TotalDays) dias</span>
                            }
                        }
                    </td>
                    <td>
                        <span class="@StatusBadge(u.Status)">
                            @u.Status
                        </span>
                    </td>
                    <td>
                        @if (u.Status != UserStatus.Removed)
                        {
                            <form method="post" asp-page-handler="Remove" style="display:inline">
                                <input type="hidden" name="id" value="@u.Id" />
                                <button type="submit"
                                        class="btn btn-danger"
                                        onclick="return confirm('Remover acesso de @u.Email ?')">
                                    Remover
                                </button>
                            </form>

                            <a asp-page="/Users/Create"
                               asp-route-id="@u.Id"
                               class="btn btn-secondary">
                                Editar grupos
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    setTimeout(() => {
        const toast = document.getElementById("toast");
        if (toast) {
            toast.style.opacity = "0";
            setTimeout(() => toast.remove(), 400);
        }
    }, 4000);
</script>